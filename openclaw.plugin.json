{
  "id": "my-plugin",
  "name": "My Plugin",
  "version": "0.1.0",
  "description": "My custom OpenClaw test plugin",
  "runtime": "node",
  "entry": "./dist/app/index.js",
  "displayName": "My Plugin",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "age": {
        "type": "integer",
        "description": "Required age value provided from openclaw.json.",
        "minimum": 0
      }
    },
    "required": [
      "age"
    ]
  }
}
